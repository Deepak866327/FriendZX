{
  "name": "post-service",
  "version": "2.0.0",
  "description": "Post & Media service — PostgreSQL, Prisma, S3, Sharp, FFmpeg",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node --transpile-only src/main.ts\"",
    "start": "node dist/src/main.js",
    "build": "tsc",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:dev": "prisma migrate dev --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.0.3",
    "multer": "^2.0.0",
    "sharp": "^0.33.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "nodemon": "^3.0.2",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
