{
  "name": "location-matcher",
  "version": "1.0.0",
  "description": "Location-based matching microservices platform",
  "private": true,
  "dependencies": {
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^7.3.3"
  },
  "scripts": {
    "docker:up": "docker-compose -f shared/docker-compose.yml up --build",
    "docker:down": "docker-compose -f shared/docker-compose.yml down",
    "docker:logs": "docker-compose -f shared/docker-compose.yml logs -f",
    "dev:frontend": "cd frontend && npm run dev"
  }
}
