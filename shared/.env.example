# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0

# Services Configuration
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_PORT=3002
USER_SERVICE_URL=http://user-service:3002
LOCATION_SERVICE_PORT=3003
LOCATION_SERVICE_URL=http://location-service:3003
NOTIFICATION_SERVICE_PORT=3004
NOTIFICATION_SERVICE_URL=http://notification-service:3004

# PostgreSQL - Auth Service
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=auth_password
POSTGRES_AUTH_DB=auth_db
POSTGRES_AUTH_HOST=postgres-auth
POSTGRES_AUTH_PORT=5432
DATABASE_URL=postgresql://auth_user:auth_password@postgres-auth:5432/auth_db

# PostgreSQL - User Service
POSTGRES_USER_USER=user_user
POSTGRES_USER_PASSWORD=user_password
POSTGRES_USER_DB=user_db
POSTGRES_USER_HOST=postgres-user
POSTGRES_USER_PORT=5432
USER_DATABASE_URL=postgresql://user_user:user_password@postgres-user:5432/user_db

# MongoDB - Location Service
MONGODB_USER=root
MONGODB_PASSWORD=password
MONGODB_DB=location_db
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_URL=mongodb://root:password@mongodb:27017/location_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# Redis Geo
REDIS_GEO_HOST=redis-geo
REDIS_GEO_PORT=6379
REDIS_GEO_URL=redis://redis-geo:6379

# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_BROKER_ID=1

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_REFRESH_EXPIRY=7d

# Node Environment
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# External APIs
OLA_MAPS_API_KEY=your_ola_maps_api_key
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret